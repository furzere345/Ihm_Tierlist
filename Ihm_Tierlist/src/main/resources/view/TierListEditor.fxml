<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="560.0" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tierlist.controller.TierListEditorController">

    <top>
        <HBox alignment="CENTER" prefHeight="55.0" spacing="130.0">
            <padding><Insets left="10.0" right="10.0" /></padding>

            <Button fx:id="btnBack" alignment="CENTER" mnemonicParsing="false" onAction="#onBack" prefHeight="32.0" prefWidth="150.0" text="Accueil" textFill="WHITE">
                <font><Font size="13.0" /></font>
            </Button>

               <Button fx:id="btnReset" mnemonicParsing="false" onAction="#onReset" prefHeight="32.0" prefWidth="150.0" text="Réinitialiser la tierlist" textFill="WHITE">
                   <font>
               <Font size="12.0" />
            </font>
               </Button>
         <Button fx:id="btnRename" mnemonicParsing="false" onAction="#onModifierTierList" prefHeight="32.0" prefWidth="150.0" text="Renommer la tierlist" textFill="WHITE" />

            <Button fx:id="btnSave" mnemonicParsing="false" onAction="#onSave" prefHeight="32.0" prefWidth="150.0" text="Exporter la tierlist" textFill="WHITE">
                <font><Font size="13.0" /></font>
            </Button>

            <Button fx:id="btnTheme" alignment="CENTER_RIGHT" mnemonicParsing="false" onAction="#onToggleTheme" prefHeight="35.0" prefWidth="35.0" text="☀" textFill="WHITE">
                <font><Font size="14.0" /></font>
            </Button>

        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <content>
                <VBox spacing="0">

                    <HBox spacing="15.0">
                        <padding><Insets bottom="15.0" left="10.0" right="10.0" top="15.0" /></padding>

                        <StackPane>
                            <StackPane fx:id="coverPane" prefHeight="90.0" prefWidth="90.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #555555;">
                                <ImageView fx:id="coverImageView" fitHeight="90.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="true" />
                                <Label fx:id="coverPlaceholder" text="280 × 280" textFill="#666666">
                                    <font><Font size="11.0" /></font>
                                </Label>
                            </StackPane>

                            <Label fx:id="itemCountBadge" style="-fx-background-color: #FF6600; -fx-background-radius: 4; -fx-padding: 2 6 2 6;" text="0" textFill="WHITE" StackPane.alignment="TOP_LEFT">
                                <font><Font size="11.0" /></font>
                            </Label>
                        </StackPane>

                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="labelTierListName" text="Nom de la Tier List" textFill="WHITE">
                                <font><Font size="24.0" /></font>
                            </Label>
                            <Label fx:id="labelDescription" text="" textFill="#AAAAAA" wrapText="true">
                                <font><Font size="14.0" /></font>
                            </Label>
                        </VBox>

                    </HBox>

                    <VBox fx:id="tiersContainer" spacing="0" />

                    <HBox alignment="CENTER_LEFT" prefHeight="40.0">
                        <padding><Insets left="10.0" /></padding>
                        <Button fx:id="btnAddTier" mnemonicParsing="false" onAction="#onAddTier" prefHeight="26.0" text="+ Ajouter un tier" textFill="WHITE">
                            <font><Font size="12.0" /></font>
                        </Button>
                    </HBox>

                    <VBox spacing="8.0">
                        <padding><Insets bottom="15.0" left="10.0" right="10.0" top="10.0" /></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="À classer" textFill="#888888">
                                <font><Font size="12.0" /></font>
                            </Label>
                            <Region HBox.hgrow="ALWAYS" />
   
                           <Button fx:id="btnAddItem" mnemonicParsing="false" onAction="#onAddItem" prefHeight="28.0" prefWidth="120.0" style="-fx-border-radius: 4; -fx-background-radius: 4;" text="+ Ajouter item" textFill="WHITE">
                               <font><Font size="12.0" /></font>
                           </Button>
                            <Button fx:id="btnAddImageItem" mnemonicParsing="false" onAction="#onAddImageItem" prefHeight="26.0" prefWidth="120.0" style="-fx-border-radius: 4; -fx-background-radius: 4;" text="+ Ajouter image" textFill="WHITE">
                                <font><Font size="12.0" /></font>
                            </Button>
                            <Button fx:id="btnImportApi" mnemonicParsing="false" onAction="#onImportApi" prefHeight="26.0" prefWidth="140.0" style="-fx-border-radius: 4; -fx-background-radius: 4;" text="+ Importer RAWG" textFill="WHITE">
                                <font><Font size="12.0" /></font>
                            </Button>
                        </HBox>
                  <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0">
                     <content>
      
                              <FlowPane fx:id="unclassifiedPane" hgap="6.0" prefHeight="100.0" prefWidth="600.0" style="-fx-border-radius: 5; -fx-background-radius: 5;" vgap="6.0">
                                  <padding>
                              <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                           </padding>
                              </FlowPane>
                     </content>
                  </ScrollPane>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
