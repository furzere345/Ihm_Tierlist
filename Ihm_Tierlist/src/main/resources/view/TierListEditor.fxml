<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="560.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tierlist.controller.TierListEditorController">

    <top>
        <HBox alignment="CENTER" prefHeight="55.0" spacing="10.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="10.0" right="10.0" /></padding>

            <Button fx:id="btnBack" mnemonicParsing="false" onAction="#onBack" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #3D81FF; -fx-background-radius: 6;" text="Accueil" textFill="WHITE">
                <font><Font size="13.0" /></font>
            </Button>

            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="btnSave" mnemonicParsing="false" onAction="#onSave" prefHeight="32.0" prefWidth="220.0" style="-fx-background-color: #3D81FF; -fx-background-radius: 6;" text="Sauvegarder la tierlist" textFill="WHITE">
                <font><Font size="13.0" /></font>
            </Button>

            <Button fx:id="btnTheme" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 20; -fx-border-color: #555555; -fx-border-radius: 20;" text="☀" textFill="WHITE">
                <font><Font size="14.0" /></font>
            </Button>

        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #1a1a1a; -fx-background: #1a1a1a;">
            <content>
                <VBox spacing="0" style="-fx-background-color: #1a1a1a;">

                    <HBox alignment="CENTER_LEFT" prefHeight="45.0" spacing="10.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
                        <padding><Insets left="10.0" right="10.0" /></padding>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnReset" mnemonicParsing="false" onAction="#onReset" prefHeight="28.0" prefWidth="170.0" style="-fx-background-color: #CC3333; -fx-background-radius: 4; -fx-border-radius: 4;" text="Réinitialiser la tier list" textFill="WHITE">
                            <font><Font size="12.0" /></font>
                        </Button>

                    </HBox>

                    <HBox spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
                        <padding><Insets bottom="15.0" left="10.0" right="10.0" top="15.0" /></padding>

                        <StackPane>
                            <StackPane fx:id="coverPane" prefHeight="90.0" prefWidth="90.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #555555;">
                                <ImageView fx:id="coverImageView" fitHeight="90.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="true" />
                                <Label fx:id="coverPlaceholder" text="280 × 280" textFill="#666666">
                                    <font><Font size="11.0" /></font>
                                </Label>
                            </StackPane>

                            <Label fx:id="itemCountBadge" style="-fx-background-color: #FF6600; -fx-background-radius: 4; -fx-padding: 2 6 2 6;" text="0" textFill="WHITE" StackPane.alignment="TOP_LEFT">
                                <font><Font size="11.0" /></font>
                            </Label>
                        </StackPane>

                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="labelTierListName" text="Nom de la Tier List" textFill="WHITE">
                                <font><Font size="15.0" /></font>
                            </Label>
                            <Label fx:id="labelDescription" text="" textFill="#AAAAAA" wrapText="true">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </VBox>

                    </HBox>

                    <VBox fx:id="tiersContainer" spacing="0" style="-fx-background-color: #1a1a1a;" />

                    <HBox alignment="CENTER_LEFT" prefHeight="40.0" style="-fx-background-color: #111111; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;">
                        <padding><Insets left="10.0" /></padding>
                        <Button fx:id="btnAddTier" mnemonicParsing="false" onAction="#onAddTier" prefHeight="26.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #666666; -fx-border-radius: 4; -fx-background-radius: 4;" text="+ Ajouter un tier" textFill="WHITE">
                            <font><Font size="12.0" /></font>
                        </Button>
                    </HBox>

                    <VBox spacing="8.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;">
                        <padding><Insets bottom="15.0" left="10.0" right="10.0" top="10.0" /></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="À classer" textFill="#888888">
                                <font><Font size="12.0" /></font>
                            </Label>
                            <Region HBox.hgrow="ALWAYS" />
   
                           <Button fx:id="btnAddItem" mnemonicParsing="false" onAction="#onAddItem" prefHeight="28.0" prefWidth="120.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #666666; -fx-border-radius: 4; -fx-background-radius: 4;" text="+ Ajouter item" textFill="WHITE">
                               <font><Font size="12.0" /></font>
                           </Button>
                            <Button fx:id="btnAddImageItem" mnemonicParsing="false" onAction="#onAddImageItem" prefHeight="26.0" prefWidth="120.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #555555; -fx-border-radius: 4; -fx-background-radius: 4;" text="+ Ajouter image" textFill="WHITE">
                                <font><Font size="12.0" /></font>
                            </Button>
                            <Button fx:id="btnImportApi" mnemonicParsing="false" onAction="#onImportApi" prefHeight="26.0" prefWidth="140.0" style="-fx-background-color: #2a2a2a; -fx-border-color: #555555; -fx-border-radius: 4; -fx-background-radius: 4;" text="+ Importer RAWG" textFill="WHITE">
                                <font><Font size="12.0" /></font>
                            </Button>
                        </HBox>

                        <FlowPane fx:id="unclassifiedPane" hgap="6.0" prefHeight="100.0" style="-fx-background-color: #222222; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5;" vgap="6.0">
                            <padding><Insets bottom="8.0" left="8.0" right="8.0" top="8.0" /></padding>
                        </FlowPane>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
