<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tierlist.controller.CreationTierListController">

    <top>
        <HBox fx:id="navbar" alignment="CENTER" prefHeight="55.0">
            <padding><Insets left="12.0" right="12.0" /></padding>

            <Button fx:id="btnAccueil" mnemonicParsing="false" onAction="#onAccueil" prefHeight="32.0" prefWidth="90.0" text="Accueil" textFill="WHITE">
                <font><Font size="14.0" /></font>
            </Button>
         <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="55.0" prefWidth="573.0" HBox.hgrow="ALWAYS" />
         <Button fx:id="buttonTheme" alignment="CENTER_RIGHT" mnemonicParsing="false" onAction="#onToggleTheme" prefHeight="30.0" prefWidth="30.0" style="-fx-background-radius: 30;" />

        </HBox>
    </top>

    <center>
        <VBox spacing="0">

            <HBox alignment="CENTER_LEFT" prefHeight="55.0">
                <padding><Insets left="30.0" /></padding>
                <Label text="Création de Tier-Lists :" textFill="WHITE">
                    <font><Font size="20.0" /></font>
                </Label>
            </HBox>

            <HBox spacing="25.0">
                <padding><Insets bottom="30.0" left="30.0" right="30.0" top="40.0" /></padding>

                <StackPane fx:id="coverImagePane" onMouseClicked="#onSelectCover" prefHeight="200.0" prefWidth="200.0">

                    <Label fx:id="coverLabel" text="280 × 280" textFill="#888888">
                        <font><Font size="14.0" /></font>
                    </Label>

                </StackPane>

                <VBox spacing="15.0" HBox.hgrow="ALWAYS">

                    <TextField fx:id="nomField" prefHeight="35.0" promptText="Nom de la Tier-List">
                    </TextField>

                    <TextArea fx:id="descriptionArea" prefHeight="120.0" promptText="Description de la Tier-List" wrapText="true">
                    </TextArea>

                </VBox>

            </HBox>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0">
            <padding><Insets left="30.0" /></padding>

            <Button fx:id="btnCommencer" mnemonicParsing="false" onAction="#onCommencer" prefHeight="38.0" prefWidth="200.0" text="Commencer la tier list !" textFill="WHITE">
                <font><Font size="14.0" /></font>
            </Button>

        </HBox>
    </bottom>

</BorderPane>
