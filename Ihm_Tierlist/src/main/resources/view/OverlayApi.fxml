<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="520.0" prefWidth="620.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tierlist.controller.OverlayApiController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="15.0" right="15.0" /></padding>

            <Label text="Importer depuis RAWG" textFill="WHITE">
                <font><Font size="16.0" /></font>
            </Label>
        </HBox>
    </top>

    <center>
        <BorderPane style="-fx-background-color: #1a1a1a;">

            <top>
                <HBox spacing="10.0" style="-fx-background-color: #1a1a1a;">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="12.0" /></padding>

                    <TextField fx:id="searchField" onAction="#onSearch" prefHeight="34.0" promptText="Rechercher un jeu..." style="-fx-background-color: #2a2a2a; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-border-color: #555555; -fx-border-radius: 5; -fx-background-radius: 5;" HBox.hgrow="ALWAYS">
                        <font><Font size="13.0" /></font>
                    </TextField>

                    <Button fx:id="searchButton" mnemonicParsing="false" onAction="#onSearch" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #3D81FF; -fx-background-radius: 5;" text="Rechercher" textFill="WHITE">
                        <font><Font size="13.0" /></font>
                    </Button>
                </HBox>
            </top>

            <bottom>
                <HBox style="-fx-background-color: #111111;">
                    <padding><Insets bottom="8.0" left="15.0" top="8.0" /></padding>
                    <Label fx:id="statusLabel" text="Entrez un nom de jeu pour commencer" textFill="#888888">
                        <font><Font size="12.0" /></font>
                    </Label>
                </HBox>
            </bottom>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #1a1a1a; -fx-background: #1a1a1a;">
                    <content>
                        <FlowPane fx:id="resultsPane" hgap="10.0" style="-fx-background-color: #1a1a1a;" vgap="10.0">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>
    </center>

</BorderPane>
