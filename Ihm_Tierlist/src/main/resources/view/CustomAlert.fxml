<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="180.0" prefWidth="350.0" spacing="20.0" style="-fx-border-width: 2;" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tierlist.controller.CustomAlertController">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <Label fx:id="labelTitre" text="Notification" textFill="WHITE">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
    </Label>

    <Label fx:id="labelMessage" alignment="CENTER" text="Opération réussie !" textAlignment="CENTER" textFill="WHITE" wrapText="true">
        <font>
            <Font size="14.0" />
        </font>
    </Label>

    <Button defaultButton="true" mnemonicParsing="false" onAction="#onFermer" prefHeight="30.0" prefWidth="100.0" style="-fx-font-weight: bold; -fx-background-radius: 4;" text="OK" />

</VBox>
